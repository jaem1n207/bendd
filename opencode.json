{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "docs/architecture.md",
    "docs/conventions.md",
    "docs/pitfalls.md",
    "docs/decisions.md",
    "docs/commands.md"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "shadcn": {
      "type": "local",
      "command": "npx",
      "args": ["shadcn@latest", "mcp"],
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "enabled": false
    }
  }
}
